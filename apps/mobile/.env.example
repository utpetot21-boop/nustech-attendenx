# ═══════════════════════════════════════════════════════════
# NUSTECH-ATTENDENX — Mobile App Environment Variables
# Copy ke .env dan isi nilai yang diperlukan
# Variabel EXPO_PUBLIC_ otomatis tersedia di client-side
# ═══════════════════════════════════════════════════════════

# ── Backend API ───────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://192.168.1.x:3001/api/v1
# Catatan: gunakan IP lokal (bukan localhost) saat development di device fisik

# ── App ───────────────────────────────────────────────────────
EXPO_PUBLIC_APP_NAME=Nustech-AttendenX
EXPO_PUBLIC_APP_VERSION=1.0.0

# ── Maps ─────────────────────────────────────────────────────
# OpenStreetMap dipakai via react-native-maps (tidak perlu key)
# Opsional: Google Maps untuk Android fallback
# EXPO_PUBLIC_GOOGLE_MAPS_KEY=AIzaSy...

# ── Sentry (opsional) ────────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=https://xxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

# ── Production ────────────────────────────────────────────────
# EXPO_PUBLIC_API_URL=https://api.attendenx.nustech.id/api/v1
