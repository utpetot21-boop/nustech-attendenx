# ═══════════════════════════════════════════════════════════
# NUSTECH-ATTENDENX — Web App Environment Variables
# Copy ke .env.local dan isi nilai yang diperlukan
# ═══════════════════════════════════════════════════════════

# ── Backend API ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3001

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Nustech-AttendenX
NEXT_PUBLIC_APP_VERSION=1.0.0

# ── Maps (OpenStreetMap + Leaflet — tidak perlu API key) ─────
# Jika ingin pakai Google Maps tiles (opsional):
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSy...

# ── Sentry (opsional) ────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

# ── Production ────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.attendenx.nustech.id/api/v1
# NEXT_PUBLIC_WS_URL=https://api.attendenx.nustech.id
