# ═══════════════════════════════════════════════════════════
# NUSTECH-ATTENDENX — Backend Environment Variables
# Copy ke .env dan isi semua nilai yang diperlukan
# ═══════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
TZ=Asia/Makassar

# URL frontend web (untuk CORS)
WEB_URL=http://localhost:3000

# ── Database (PostgreSQL 16) ─────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=attendenx
DB_PASSWORD=attendenx_pass
DB_NAME=attendenx_db
DB_SSL=false

# ── Redis 7 ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=86400

# ── JWT Auth ─────────────────────────────────────────────────
# WAJIB: ganti dengan random string panjang di production
# Generate: openssl rand -hex 64
JWT_SECRET=GANTI_INI_DENGAN_SECRET_PANJANG_DAN_RANDOM_MIN_64_KARAKTER
JWT_REFRESH_SECRET=GANTI_INI_DENGAN_REFRESH_SECRET_BERBEDA_DARI_JWT_SECRET
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
BCRYPT_ROUNDS=12

# ── Cloudflare R2 (Storage) ──────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=attendenx-storage
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Firebase Cloud Messaging (FCM) ───────────────────────────
FCM_PROJECT_ID=your_firebase_project_id
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# ── Resend (Email) ───────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@nustech-attendenx.id
RESEND_FROM_NAME=Nustech-AttendenX

# ── WhatsApp (self-hosted via whatsapp-web.js) ───────────────
WA_PHONE_NUMBER=6281234567890
WA_SESSION_PATH=./wa-session

# ── Nominatim (Geocoding) ────────────────────────────────────
# OpenStreetMap Nominatim — gratis, tidak perlu API key
# Tapi wajib set User-Agent yang informatif
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=NustechAttendenX/1.0 (contact@nustech.id)

# ── OSRM (Routing) ───────────────────────────────────────────
# Public OSRM — atau self-hosted di VPS
OSRM_BASE_URL=https://router.project-osrm.org

# ── Sentry (Error Tracking) ──────────────────────────────────
SENTRY_DSN=https://xxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX

# ── Backup & Restore (AES-256 encryption before R2 upload) ───
# Generate: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=
# Generate: openssl rand -hex 16
BACKUP_IV=
BACKUP_RETENTION_DAYS=30
BACKUP_NOTIFY_EMAIL=admin@nustech.id
BACKUP_R2_PATH=backups/

# ── VPS / Production ─────────────────────────────────────────
# Hanya diisi saat deploy ke VPS
# VPS_IP=76.13.23.42
# DOMAIN=attendenx.nustech.id
# TRAEFIK_EMAIL=devops@nustech.id
