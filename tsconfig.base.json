{
  "compilerOptions": {
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "target": "ES2020",
    "lib": ["ES2020"],
    "paths": {
      "@nustech/shared": ["../../shared/src/index.ts"]
    }
  },
  "exclude": ["node_modules"]
}
